---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "That One Paper — a short-form video series from the Donders Institute where researchers share the single paper that changed them.",
} = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href={base + "favicon.png"} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Archivo:wght@400;500;700;900&family=DM+Serif+Display:ital@0;1&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="top-body">
    <slot />
  </body>
</html>

<style is:global>
  @import "../styles/that-one-paper.css";

  .top-body {
    margin: 0;
    background: var(--top-bg);
    color: var(--top-fg);
    font-family: var(--top-font-body);
    font-size: var(--top-text-base);
    font-weight: var(--top-weight-body);
    line-height: var(--top-leading-normal);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
  }

  .top-body * { box-sizing: border-box; }

  .top-body h1, .top-body h2, .top-body h3 {
    font-family: var(--top-font-display);
    font-weight: var(--top-weight-heavy);
    letter-spacing: var(--top-track-display);
    line-height: var(--top-leading-tight);
    margin: 0;
    text-transform: uppercase;
  }

  .top-body p { margin: 0; }

  .top-body a {
    color: inherit;
    text-decoration: none;
    transition: color var(--top-duration-fast) var(--top-ease);
  }

  .top-body ::selection {
    background: var(--top-coral);
    color: var(--top-ivory);
  }

  @media (prefers-reduced-motion: reduce) {
    .top-body *, .top-body *::before, .top-body *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
